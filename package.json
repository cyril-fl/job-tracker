{
  "name": "job-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter client --filter api run dev",
    "dev:client": "pnpm --filter client run dev",
    "dev:api": "pnpm --filter api run dev",
    "build": "pnpm -r run build",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json}": ["biome check --write --no-errors-on-unmatched"]
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": ["@biomejs/biome", "better-sqlite3", "esbuild"]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "shared": "workspace:*",
    "vitest": "^4.1.0",
    "zod": "catalog:"
  }
}
